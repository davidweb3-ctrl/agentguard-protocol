{
  "name": "@agentguard/x402-demo-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent": "pnpm --filter @agentguard/sdk build && tsx src/agent-client.ts",
    "agent:over-limit": "pnpm --filter @agentguard/sdk build && tsx src/agent-over-limit.ts",
    "check:pause-action": "tsx src/check-pause-action.ts",
    "dev": "pnpm --filter @agentguard/sdk build && tsx src/server.ts",
    "seed": "pnpm --filter @agentguard/sdk build && tsx src/seed-demo.ts",
    "typecheck": "pnpm --filter @agentguard/sdk build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentguard/sdk": "workspace:*",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}
